model AllTimeMetrics {
  id       Int       @id @default(autoincrement())
  category Category?
  rollup   Rollup?

  updatedAt DateTime @default(now()) @map("updated_at")

  // ------------- GLOBAL-ONLY METRICS -------------

  // Averages

  /// @zod.nonnegative()
  avgBlobBaseFee  Float? @map("avg_blob_base_fee")
  /// @zod.nonnegative()
  avgBlobGasPrice Float? @map("avg_blob_gas_price")

  // Counters

  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobBaseFee  Decimal? @map("total_blob_base_fee")
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobGasPrice Decimal? @map("total_blob_gas_price") @db.Decimal(100, 0)
  /// @zod.nonnegative()
  totalBlocks       Int?     @map("total_blocks")

  // ------------- DIMENSIONAL METRICS -------------

  // Averages

  /// @zod.nonnegative()
  avgBlobAsCalldataFee    Float? @map("avg_blob_as_calldata_fee")
  /// @zod.nonnegative()
  avgBlobAsCalldataMaxFee Float? @map("avg_blob_as_calldata_max_fee")
  /// @zod.nonnegative()
  avgBlobMaxFee           Float? @map("avg_blob_max_fee")
  /// @zod.nonnegative()
  avgBlobUsageSize        Float? @map("avg_blob_usage_size")
  /// @zod.nonnegative()
  avgMaxBlobGasFee        Float? @map("avg_max_blob_gas_fee")

  // Counters 

  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobAsCalldataFee     Decimal? @map("total_blob_as_calldata_fee") @db.Decimal(100, 0)
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobAsCalldataGasUsed Decimal? @map("total_blob_as_calldata_gas_used") @db.Decimal(100, 0)
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobAsCalldataMaxFee  Decimal? @map("total_blob_as_calldata_max_fee") @db.Decimal(100, 0)
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobGasUsed           Decimal? @map("total_blob_gas_used") @db.Decimal(100, 0)
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobMaxFee            Decimal? @map("total_blob_max_fee") @db.Decimal(100, 0)
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalBlobMaxGasFee         Decimal? @map("total_blob_max_gas_fee") @db.Decimal(100, 0)
  /// @zod.nonnegative()
  totalBlobs                 Int?     @map("total_blobs")
  /// @zod.nonnegative()
  totalBlobSize              BigInt?  @map("total_blob_size")
  /// @zod.nonnegative()
  totalBlobUsageSize         BigInt?  @map("total_blob_usage_size")
  /// @zod.nonnegative()
  totalTransactions          Int?     @map("total_transactions")
  /// @zod.nonnegative()
  totalUniqueBlobs           Int?     @map("total_unique_blobs")
  /// @zod.nonnegative()
  totalUniqueReceivers       Int?     @map("total_unique_receivers")
  /// @zod.nonnegative()
  totalUniqueSenders         Int?     @map("total_unique_senders")
  /// @zod.custom(imports.nonNegativeDecimalSchema)
  totalMaxBlobGasFee         Decimal? @map("total_max_blob_gas_fee") @db.Decimal(100, 0)

  @@unique([category, rollup])
  @@map("all_time_metrics")
}

