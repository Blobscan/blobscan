{
  "name": "@blobscan/analytics",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm with-env uv run dagster dev -p 3003",
    "lint": "uv run ruff check analytics/ tests/",
    "lint:fix": "uv run ruff check --fix analytics/ tests/",
    "type-check": "uv run mypy analytics/",
    "test": "uv run pytest tests/ -v",
    "start": "uv run dagster-webserver -h 0.0.0.0 -p 3003",
    "with-env": "dotenv -e ../../.env --",
    "with-env:test": "dotenv -e ../../.env.test --"
  },
  "devDependencies": {
    "@prisma/client": "^5.22.0"
  }
}
